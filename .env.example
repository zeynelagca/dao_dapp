# ─── Wallet Private Key (NEVER share or commit this!) ───
PRIVATE_KEY=your_metamask_private_key_here

# ─── Polygon Amoy Testnet RPC ───
AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# ─── Polygon Mainnet RPC (for production) ───
POLYGON_RPC_URL=https://polygon-rpc.com

# ─── PolygonScan API Key (for contract verification) ───
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here

# ─── Deployed Contract Addresses (filled after deployment) ───
VITE_GAZAIN_ADDRESS=0x_DEPLOYED_TOKEN_ADDRESS
VITE_NFT_ADDRESS=0x_DEPLOYED_NFT_ADDRESS
