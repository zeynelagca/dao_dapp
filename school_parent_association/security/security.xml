<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_spa" model="ir.module.category">
        <field name="name">Okul Aile Birliği</field>
        <field name="description">Okul Aile Birliği rollerini yönetir.</field>
        <field name="sequence">25</field>
    </record>

    <record id="group_spa_admin" model="res.groups">
        <field name="name">SPA Yönetici</field>
        <field name="category_id" ref="school_parent_association.module_category_spa"/>
    </record>
    <record id="group_spa_principal" model="res.groups">
        <field name="name">SPA Müdür</field>
        <field name="category_id" ref="school_parent_association.module_category_spa"/>
    </record>
    <record id="group_spa_president" model="res.groups">
        <field name="name">SPA Başkan</field>
        <field name="category_id" ref="school_parent_association.module_category_spa"/>
    </record>
    <record id="group_spa_treasurer" model="res.groups">
        <field name="name">SPA Sayman</field>
        <field name="category_id" ref="school_parent_association.module_category_spa"/>
    </record>
    <record id="group_spa_auditor" model="res.groups">
        <field name="name">SPA Denetçi</field>
        <field name="category_id" ref="school_parent_association.module_category_spa"/>
    </record>
    <record id="group_spa_representative" model="res.groups">
        <field name="name">SPA Temsilci</field>
        <field name="category_id" ref="school_parent_association.module_category_spa"/>
    </record>
    <record id="group_spa_teacher_requester" model="res.groups">
        <field name="name">SPA Öğretmen Talepçi</field>
        <field name="category_id" ref="school_parent_association.module_category_spa"/>
    </record>
    <record id="group_spa_readonly" model="res.groups">
        <field name="name">SPA Salt Okunur</field>
        <field name="category_id" ref="school_parent_association.module_category_spa"/>
    </record>

    <record id="spa_rule_school_scope_meeting" model="ir.rule">
        <field name="name">SPA Okul Kuralı - Toplantı</field>
        <field name="model_id" ref="model_spa_meeting"/>
        <field name="domain_force">['|',('school_id.principal_id','=',user.id),('create_uid','=',user.id)]</field>
        <field name="groups" eval="[(4, ref('school_parent_association.group_spa_principal')), (4, ref('school_parent_association.group_spa_president')), (4, ref('school_parent_association.group_spa_treasurer')), (4, ref('school_parent_association.group_spa_auditor')), (4, ref('school_parent_association.group_spa_representative')), (4, ref('school_parent_association.group_spa_teacher_requester')), (4, ref('school_parent_association.group_spa_readonly'))]"/>
    </record>
    <record id="spa_rule_school_scope_donation" model="ir.rule">
        <field name="name">SPA Okul Kuralı - Bağış</field>
        <field name="model_id" ref="model_spa_donation"/>
        <field name="domain_force">['|',('school_id.principal_id','=',user.id),('create_uid','=',user.id)]</field>
        <field name="groups" eval="[(4, ref('school_parent_association.group_spa_principal')), (4, ref('school_parent_association.group_spa_president')), (4, ref('school_parent_association.group_spa_treasurer')), (4, ref('school_parent_association.group_spa_auditor')), (4, ref('school_parent_association.group_spa_representative')), (4, ref('school_parent_association.group_spa_teacher_requester')), (4, ref('school_parent_association.group_spa_readonly'))]"/>
    </record>
    <record id="spa_rule_school_scope_expense" model="ir.rule">
        <field name="name">SPA Okul Kuralı - Gider</field>
        <field name="model_id" ref="model_spa_expense_request"/>
        <field name="domain_force">['|',('school_id.principal_id','=',user.id),('create_uid','=',user.id)]</field>
        <field name="groups" eval="[(4, ref('school_parent_association.group_spa_principal')), (4, ref('school_parent_association.group_spa_president')), (4, ref('school_parent_association.group_spa_treasurer')), (4, ref('school_parent_association.group_spa_auditor')), (4, ref('school_parent_association.group_spa_representative')), (4, ref('school_parent_association.group_spa_teacher_requester')), (4, ref('school_parent_association.group_spa_readonly'))]"/>
    </record>
</odoo>
