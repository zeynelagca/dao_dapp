<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="spa_need_request_action" model="ir.actions.act_window"><field name="name">İhtiyaç Talepleri</field><field name="res_model">spa.need.request</field><field name="view_mode">tree,form,kanban,pivot</field></record>
    <record id="spa_need_request_tree" model="ir.ui.view"><field name="name">spa.need.request.tree</field><field name="model">spa.need.request</field><field name="arch" type="xml"><tree><field name="name"/><field name="school_id"/><field name="request_source"/><field name="priority"/><field name="request_date"/><field name="estimated_budget"/><field name="state"/></tree></field></record>
    <record id="spa_need_request_form" model="ir.ui.view"><field name="name">spa.need.request.form</field><field name="model">spa.need.request</field><field name="arch" type="xml"><form><header><button name="action_submit" type="object" string="Gönder" invisible="state != 'draft'"/><button name="action_under_review" type="object" string="İncelemeye Al" invisible="state != 'submitted'"/><button name="action_approve" type="object" string="Onayla" invisible="state != 'under_review'" class="btn-primary"/><button name="action_reject" type="object" string="Reddet" invisible="state not in ('submitted','under_review')"/><button name="action_convert_to_expense" type="object" string="Gidere Dönüştür" invisible="state != 'approved'"/><button name="action_done" type="object" string="Tamamla" invisible="state not in ('converted','approved')"/><field name="state" widget="statusbar" statusbar_visible="draft,submitted,under_review,approved,converted,rejected,done"/></header><sheet><group><group><field name="name"/><field name="school_id"/><field name="union_term_id"/><field name="request_source"/><field name="priority"/><field name="request_date"/></group><group><field name="requested_by_partner_id"/><field name="requested_by_user_id"/><field name="category"/><field name="estimated_budget"/><field name="expense_request_id" readonly="1"/></group></group><field name="description"/></sheet><chatter/></form></field></record>

    <record id="spa_event_action" model="ir.actions.act_window"><field name="name">Etkinlikler</field><field name="res_model">spa.event</field><field name="view_mode">tree,form,calendar,pivot,graph</field></record>
    <record id="spa_event_tree" model="ir.ui.view"><field name="name">spa.event.tree</field><field name="model">spa.event</field><field name="arch" type="xml"><tree><field name="name"/><field name="school_id"/><field name="event_type"/><field name="event_date"/><field name="budget_amount"/><field name="income_amount"/><field name="expense_amount"/><field name="state"/></tree></field></record>
    <record id="spa_event_form" model="ir.ui.view"><field name="name">spa.event.form</field><field name="model">spa.event</field><field name="arch" type="xml"><form><sheet><div class="oe_button_box" name="button_box"><button type="object" class="oe_stat_button" name="action_view_donations" icon="fa-heart"><field name="donation_count" widget="statinfo" string="Bağış"/></button><button type="object" class="oe_stat_button" name="action_view_expenses" icon="fa-money"><field name="expense_count" widget="statinfo" string="Gider"/></button></div><group><group><field name="name"/><field name="school_id"/><field name="union_term_id"/><field name="event_type"/><field name="event_date"/><field name="location"/></group><group><field name="responsible_partner_id"/><field name="budget_amount"/><field name="income_amount"/><field name="expense_amount"/><field name="state"/></group></group><field name="notes"/></sheet><chatter/></form></field></record>
</odoo>
