<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="spa_member_role_action" model="ir.actions.act_window">
        <field name="name">Üye Rolleri</field>
        <field name="res_model">spa.member.role</field>
        <field name="view_mode">tree,form</field>
    </record>
    <record id="spa_member_role_tree" model="ir.ui.view">
        <field name="name">spa.member.role.tree</field><field name="model">spa.member.role</field>
        <field name="arch" type="xml"><tree><field name="name"/><field name="code"/></tree></field>
    </record>
    <record id="spa_member_role_form" model="ir.ui.view">
        <field name="name">spa.member.role.form</field><field name="model">spa.member.role</field>
        <field name="arch" type="xml"><form><sheet><group><field name="name"/><field name="code"/></group></sheet></form></field>
    </record>

    <record id="spa_board_member_action" model="ir.actions.act_window"><field name="name">Kurul Üyeleri</field><field name="res_model">spa.board.member</field><field name="view_mode">tree,form</field></record>
    <record id="spa_board_member_tree" model="ir.ui.view"><field name="name">spa.board.member.tree</field><field name="model">spa.board.member</field><field name="arch" type="xml"><tree><field name="union_term_id"/><field name="partner_id"/><field name="role_id"/><field name="board_type"/><field name="active"/></tree></field></record>
    <record id="spa_board_member_form" model="ir.ui.view"><field name="name">spa.board.member.form</field><field name="model">spa.board.member</field><field name="arch" type="xml"><form><sheet><group><field name="union_term_id"/><field name="partner_id"/><field name="role_id"/><field name="board_type"/><field name="date_start"/><field name="date_end"/><field name="active"/></group></sheet></form></field></record>

    <record id="spa_announcement_action" model="ir.actions.act_window"><field name="name">Duyurular</field><field name="res_model">spa.announcement</field><field name="view_mode">tree,form,kanban</field></record>
    <record id="spa_announcement_tree" model="ir.ui.view"><field name="name">spa.announcement.tree</field><field name="model">spa.announcement</field><field name="arch" type="xml"><tree><field name="name"/><field name="school_id"/><field name="target_scope"/><field name="publish_date"/><field name="expiry_date"/><field name="active"/></tree></field></record>
    <record id="spa_announcement_form" model="ir.ui.view"><field name="name">spa.announcement.form</field><field name="model">spa.announcement</field><field name="arch" type="xml"><form><sheet><group><field name="name"/><field name="school_id"/><field name="union_term_id"/><field name="target_scope"/><field name="publish_date"/><field name="expiry_date"/><field name="active"/></group><notebook><page string="İçerik"><field name="content_html"/></page></notebook></sheet><chatter/></form></field></record>

    <record id="spa_audit_note_action" model="ir.actions.act_window"><field name="name">Denetim Notları</field><field name="res_model">spa.audit.note</field><field name="view_mode">tree,form</field></record>
    <record id="spa_audit_note_tree" model="ir.ui.view"><field name="name">spa.audit.note.tree</field><field name="model">spa.audit.note</field><field name="arch" type="xml"><tree><field name="note_date"/><field name="school_id"/><field name="note_type"/><field name="resolved"/><field name="resolved_date"/></tree></field></record>
    <record id="spa_audit_note_form" model="ir.ui.view"><field name="name">spa.audit.note.form</field><field name="model">spa.audit.note</field><field name="arch" type="xml"><form><header><button name="action_mark_resolved" type="object" string="Çözüldü İşaretle" invisible="resolved"/><field name="resolved"/></header><sheet><group><field name="school_id"/><field name="union_term_id"/><field name="note_date"/><field name="note_type"/><field name="reference_model"/><field name="reference_res_id"/></group><group><field name="description"/><field name="action_required"/><field name="resolved_date"/></group></sheet><chatter/></form></field></record>

    <record id="spa_tefbis_export_action" model="ir.actions.act_window"><field name="name">TEFBİS Dışa Aktarım</field><field name="res_model">spa.tefbis.export</field><field name="view_mode">tree,form</field></record>
    <record id="spa_tefbis_export_tree" model="ir.ui.view"><field name="name">spa.tefbis.export.tree</field><field name="model">spa.tefbis.export</field><field name="arch" type="xml"><tree><field name="name"/><field name="school_id"/><field name="export_date"/><field name="export_type"/><field name="line_count"/><field name="state"/></tree></field></record>
    <record id="spa_tefbis_export_form" model="ir.ui.view"><field name="name">spa.tefbis.export.form</field><field name="model">spa.tefbis.export</field><field name="arch" type="xml"><form><header><button name="action_generate" type="object" string="Oluştur" invisible="state != 'draft'" class="btn-primary"/><button name="action_mark_exported" type="object" string="Dışa Aktarıldı" invisible="state != 'generated'"/><field name="state" widget="statusbar" statusbar_visible="draft,generated,exported"/></header><sheet><group><field name="name"/><field name="school_id"/><field name="union_term_id"/><field name="export_date"/><field name="export_type"/><field name="line_count"/></group><group><field name="data_json" widget="text"/></group></sheet><chatter/></form></field></record>
</odoo>
