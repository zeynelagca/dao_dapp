<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="spa_meeting_action" model="ir.actions.act_window">
        <field name="name">Toplantılar</field>
        <field name="res_model">spa.meeting</field>
        <field name="view_mode">list,form,calendar,pivot,graph</field>
    </record>
    <record id="spa_meeting_tree" model="ir.ui.view"><field name="name">spa.meeting.tree</field><field name="model">spa.meeting</field><field name="arch" type="xml"><list><field name="sequence_no"/><field name="name"/><field name="school_id"/><field name="meeting_type"/><field name="date"/><field name="attendee_count"/><field name="state"/></list></field></record>
    <record id="spa_meeting_form" model="ir.ui.view"><field name="name">spa.meeting.form</field><field name="model">spa.meeting</field><field name="arch" type="xml"><form><header><button name="button_confirm" type="object" string="Onayla" invisible="state != 'draft'"/><button name="button_done" type="object" string="Tamamla" invisible="state != 'confirmed'" class="btn-primary"/><button name="button_cancel" type="object" string="İptal" invisible="state == 'cancelled'"/><field name="state" widget="statusbar" statusbar_visible="draft,confirmed,done,cancelled"/></header><sheet><group><group><field name="name"/><field name="sequence_no" readonly="1"/><field name="school_id"/><field name="union_term_id"/><field name="meeting_type"/></group><group><field name="date"/><field name="location"/><field name="attendee_ids" widget="many2many_tags"/><field name="attendee_count" readonly="1"/><field name="quorum_count"/></group></group><notebook><page string="Gündem"><field name="agenda_line_ids"><list editable="bottom"><field name="sequence"/><field name="title"/><field name="description"/></list></field></page><page string="Kararlar"><field name="decision_ids"><list><field name="sequence_no"/><field name="subject"/><field name="decision_date"/><field name="amount"/><field name="state"/></list></field></page><page string="Notlar"><field name="notes"/></page></notebook></sheet><chatter/></form></field></record>

    <record id="spa_decision_action" model="ir.actions.act_window"><field name="name">Kararlar</field><field name="res_model">spa.decision</field><field name="view_mode">list,form,pivot,graph</field></record>
    <record id="spa_decision_tree" model="ir.ui.view"><field name="name">spa.decision.tree</field><field name="model">spa.decision</field><field name="arch" type="xml"><list><field name="sequence_no"/><field name="name"/><field name="school_id"/><field name="decision_date"/><field name="subject"/><field name="amount"/><field name="state"/></list></field></record>
    <record id="spa_decision_form" model="ir.ui.view"><field name="name">spa.decision.form</field><field name="model">spa.decision</field><field name="arch" type="xml"><form><header><button name="action_approve" type="object" string="Onayla" invisible="state != 'draft'" class="btn-primary"/><button name="action_cancel" type="object" string="İptal" invisible="state == 'cancelled'"/><field name="state" widget="statusbar" statusbar_visible="draft,approved,cancelled"/></header><sheet><group><field name="name"/><field name="sequence_no" readonly="1"/><field name="meeting_id"/><field name="school_id"/><field name="union_term_id"/><field name="decision_date"/><field name="subject"/><field name="amount"/></group><group><field name="related_model"/><field name="related_res_id"/><field name="description"/></group></sheet><chatter/></form></field></record>
</odoo>
