<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="spa_donation_action" model="ir.actions.act_window"><field name="name">Bağışlar</field><field name="res_model">spa.donation</field><field name="view_mode">list,form,pivot,graph</field></record>
    <record id="spa_donation_tree" model="ir.ui.view"><field name="name">spa.donation.tree</field><field name="model">spa.donation</field><field name="arch" type="xml"><list><field name="sequence_no"/><field name="donation_date"/><field name="school_id"/><field name="donor_id"/><field name="donation_type"/><field name="amount"/><field name="state"/></list></field></record>
    <record id="spa_donation_form" model="ir.ui.view"><field name="name">spa.donation.form</field><field name="model">spa.donation</field><field name="arch" type="xml"><form><header><button name="action_confirm" type="object" string="Onayla" invisible="state != 'draft'" class="btn-primary"/><button name="action_cancel" type="object" string="İptal" invisible="state == 'cancelled'"/><field name="state" widget="statusbar" statusbar_visible="draft,confirmed,cancelled"/></header><sheet><group><group><field name="name"/><field name="sequence_no" readonly="1"/><field name="school_id"/><field name="union_term_id"/><field name="donation_date"/></group><group><field name="donor_id"/><field name="donor_name_manual" placeholder="Anonim bağışçı veya manuel isim"/><field name="donation_type"/><field name="amount"/><field name="tefbis_ready"/><field name="document_attachment_count" readonly="1"/></group></group><field name="description"/></sheet><chatter/></form></field></record>

    <record id="spa_expense_request_action" model="ir.actions.act_window"><field name="name">Gider Talepleri</field><field name="res_model">spa.expense.request</field><field name="view_mode">list,form,pivot,graph</field></record>
    <record id="spa_expense_request_tree" model="ir.ui.view"><field name="name">spa.expense.request.tree</field><field name="model">spa.expense.request</field><field name="arch" type="xml"><list><field name="sequence_no"/><field name="name"/><field name="school_id"/><field name="request_date"/><field name="estimated_amount"/><field name="approved_amount"/><field name="payment_state"/><field name="state"/></list></field></record>
    <record id="spa_expense_request_form" model="ir.ui.view"><field name="name">spa.expense.request.form</field><field name="model">spa.expense.request</field><field name="arch" type="xml"><form><header><button name="action_submit" type="object" string="Gönder" invisible="state != 'draft'" class="btn-primary"/><button name="action_approve" type="object" string="Onayla" invisible="state not in ('submitted','draft')"/><button name="action_reject" type="object" string="Reddet" invisible="state not in ('submitted','approved')"/><button name="action_mark_paid" type="object" string="Ödendi" invisible="state != 'approved'"/><button name="action_cancel" type="object" string="İptal" invisible="state == 'cancelled'"/><field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,rejected,paid,cancelled"/></header><sheet><group><group><field name="name"/><field name="sequence_no" readonly="1"/><field name="school_id"/><field name="union_term_id"/><field name="request_date"/><field name="requested_by_id"/></group><group><field name="category"/><field name="estimated_amount"/><field name="approved_amount"/><field name="payment_state"/><field name="decision_id"/><field name="vendor_id"/></group></group><field name="description"/></sheet><chatter/></form></field></record>
</odoo>
