<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_spa_meeting_minutes"><t t-call="web.external_layout"><div class="page" t-foreach="docs" t-as="o"><h2>Toplantı Tutanağı</h2><p><strong>No:</strong> <span t-esc="o.sequence_no"/></p><p><strong>Toplantı:</strong> <span t-esc="o.name"/></p><p><strong>Tarih:</strong> <span t-esc="o.date"/></p><p><strong>Yer:</strong> <span t-esc="o.location"/></p><p><strong>Notlar:</strong></p><div t-field="o.notes"/></div></t></template>
    <template id="report_spa_decision"><t t-call="web.external_layout"><div class="page" t-foreach="docs" t-as="o"><h2>Karar Formu</h2><p><strong>Karar No:</strong> <span t-esc="o.sequence_no"/></p><p><strong>Konu:</strong> <span t-esc="o.subject"/></p><p><strong>Tarih:</strong> <span t-esc="o.decision_date"/></p><p><strong>Tutar:</strong> <span t-esc="o.amount"/></p><p><strong>Açıklama:</strong> <span t-esc="o.description"/></p></div></t></template>
    <template id="report_spa_donation_receipt"><t t-call="web.external_layout"><div class="page" t-foreach="docs" t-as="o"><h2>Bağış Kayıt Belgesi</h2><p><strong>Bağış No:</strong> <span t-esc="o.sequence_no"/></p><p><strong>Bağışçı:</strong> <span t-esc="o.donor_id.name or o.donor_name_manual"/></p><p><strong>Tarih:</strong> <span t-esc="o.donation_date"/></p><p><strong>Tutar:</strong> <span t-esc="o.amount"/></p><p><strong>Tür:</strong> <span t-esc="o.donation_type"/></p></div></t></template>
    <template id="report_spa_expense_summary"><t t-call="web.external_layout"><div class="page" t-foreach="docs" t-as="o"><h2>Gider Özeti</h2><p><strong>Talep No:</strong> <span t-esc="o.sequence_no"/></p><p><strong>Talep:</strong> <span t-esc="o.name"/></p><p><strong>Tahmini Tutar:</strong> <span t-esc="o.estimated_amount"/></p><p><strong>Onaylı Tutar:</strong> <span t-esc="o.approved_amount"/></p><p><strong>Durum:</strong> <span t-esc="o.state"/></p></div></t></template>
    <template id="report_spa_union_term_summary"><t t-call="web.external_layout"><div class="page" t-foreach="docs" t-as="o"><h2>Dönem Özeti</h2><p><strong>Dönem:</strong> <span t-esc="o.name"/></p><p><strong>Okul:</strong> <span t-esc="o.school_id.name"/></p><p><strong>Aralık:</strong> <span t-esc="o.date_start"/> - <span t-esc="o.date_end"/></p><p><strong>Toplantı:</strong> <span t-esc="o.meeting_count"/></p><p><strong>Bağış:</strong> <span t-esc="o.donation_count"/></p><p><strong>Gider:</strong> <span t-esc="o.expense_count"/></p><p><strong>Etkinlik:</strong> <span t-esc="o.event_count"/></p></div></t></template>
</odoo>
