<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="ir_cron_spa_archive_expired_announcements" model="ir.cron">
        <field name="name">SPA Süresi Dolan Duyuruları Arşivle</field>
        <field name="model_id" ref="model_spa_announcement"/>
        <field name="state">code</field>
        <field name="code">model.cron_archive_expired_announcements()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>
    <record id="ir_cron_spa_unresolved_audit_notes" model="ir.cron">
        <field name="name">SPA Bekleyen Denetim Notları</field>
        <field name="model_id" ref="model_spa_audit_note"/>
        <field name="state">code</field>
        <field name="code">model.cron_unresolved_audit_notes()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>
    <record id="ir_cron_spa_union_term_nearing_end" model="ir.cron">
        <field name="name">SPA Dönem Bitiş Uyarısı</field>
        <field name="model_id" ref="model_spa_union_term"/>
        <field name="state">code</field>
        <field name="code">model.cron_terms_near_end()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>
</odoo>
